# web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# api
# PostgreSQL runs inside Docker on container port 5432,
# but is exposed to the host on port 5434 (see docker-compose.yml).
# The DATABASE_URL must use the host-mapped port.
POSTGRES_PORT=5434
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/hsah
JWT_SECRET=change-me
JWT_ISSUER=hsah
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
