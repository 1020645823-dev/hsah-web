# web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# api
# PostgreSQL runs inside Docker on container port 5432,
# but is exposed to the host on port 5434 (see docker-compose.yml).
# The DATABASE_URL must use the host-mapped port.
POSTGRES_PORT=5434
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/hsah
JWT_SECRET=change-me
JWT_ISSUER=hsah
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Built-in super administrator (auto-created on API startup).
# Override these to change the admin credentials.
ADMIN_EMAIL=admin@hsah.local
ADMIN_PASSWORD=Admin@123

# MinIO object storage.
# MINIO_ENDPOINT is the address the API connects to (host-mapped port for local dev).
# MINIO_INTERNAL_ENDPOINT is used inside Docker (service name).
# MINIO_EXTERNAL_ENDPOINT is the address embedded in presigned URLs so the browser can reach MinIO.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost:9000
MINIO_INTERNAL_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hsah
MINIO_SECURE=false
